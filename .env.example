# ===========================================
# Hackitise Labs — Environment Configuration
# ===========================================

# Frontend Configuration
VITE_API_URL=http://localhost:4000/api/v1

# Backend Configuration
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hackitise
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/hackitise

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# SMTP (Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Notification Recipients
CONTACT_EMAIL=info@hackitiselabs.in
HR_EMAIL=Hr@hackitiselabs.in

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173
